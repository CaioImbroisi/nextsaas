# Database
# Rode: docker-compose up -d
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nextsaas"

# Next Auth
# URL do app em desenvolvimento
NEXTAUTH_URL="http://localhost:3000"
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=""

# Stripe
# Acesse: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Gere com: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# Em produção, configure em: https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=""

# Nodemailer (para envio de emails, como confirmação de email e notificações de cobrança)
# Use o Gmail: https://myaccount.google.com/apppasswords
EMAIL_SERVER_HOST=""
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM=""

# Google OAuth (opcional)
# Crie em: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""